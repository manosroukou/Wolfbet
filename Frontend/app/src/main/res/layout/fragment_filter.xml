<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title — centered -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text="Filter Games"
            android:textColor="#4FC3F7"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- BET CATEGORY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bet Category"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnBetAll"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="All"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnBetLow"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="$"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnBetMid"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="$$"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnBetHigh"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="$$$"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- RISK LEVEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk Level"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnRiskAll"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="All"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRiskLow"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Low"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRiskMed"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="Med"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRiskHigh"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="High"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- MIN STARS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minimum Stars"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp">

            <ImageView
                android:id="@+id/star1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="1 star" />

            <ImageView
                android:id="@+id/star2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="2 stars" />

            <ImageView
                android:id="@+id/star3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="3 stars" />

            <ImageView
                android:id="@+id/star4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="4 stars" />

            <ImageView
                android:id="@+id/star5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/btn_star_big_off"
                android:contentDescription="5 stars" />
        </LinearLayout>

        <!-- ACTION BUTTONS -->
        <Button
            android:id="@+id/btnApplyFilter"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Apply Filters"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#4FC3F7"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnResetFilter"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Reset"
            android:textColor="#4FC3F7"
            android:textSize="14sp" />

        <!-- RESULTS SECTION -->
        <TextView
            android:id="@+id/tvResultsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="Results"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/hsvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/llFilterResults"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvNoResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="No games found"
            android:textColor="#666666"
            android:textSize="15sp"
            android:visibility="gone" />



    </LinearLayout>
</ScrollView>